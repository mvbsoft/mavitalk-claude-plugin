{
  "mcpServers": {
    "context7": { "type": "http", "url": "https://mcp.context7.com/mcp" }
  },
  "version": "2.0.0",
  "name": "mavitalk",
  "description": "Project-agnostic Claude Code workflow & cost layer: user-only session commands (start-session, end-session) around a persisted handoff, shared discipline skills, cross-project standards injected at session start, a cost-routing profile (opusplan + pinned effort), and a sub-agent fan-out governor (agent throttle).",
  "author": {
    "name": "malina"
  },
  "keywords": [
    "mavitalk",
    "workflow",
    "skills",
    "session",
    "handoff",
    "verification",
    "wrap-up",
    "commit"
  ],
  "hooks": {
    "PreToolUse": [
      { "matcher": "Agent|Task|Workflow|Skill", "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/agent-throttle.sh", "timeout": 5 } ] }
    ],
    "SessionStart": [
      { "matcher": "startup|resume", "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/inject-standards.sh", "timeout": 5 } ] },
      { "matcher": "startup|resume", "hooks": [ { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-config-guard.sh", "timeout": 5 } ] }
    ]
  }
}
